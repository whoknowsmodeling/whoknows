ontainer mx-auto px-4 lg:px-8 py-12 lg:py-16\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12\"><div class=\"lg:col-span-2\"><a class=\"inline-block font-serif text-2xl font-bold tracking-tight text-white mb-4\" href=\"/\">WhoKnows<span class=\"font-light\">Models</span></a><p class=\"text-neutral-400 text-sm leading-relaxed max-w-md mb-6\">An international modelling agency representing the finest talent worldwide. Discover our roster of exceptional models for fashion, editorial, and commercial work.</p><div class=\"flex items-center gap-4\"><a href=\"https://instagram.com/whoknows.models\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors\" aria-label=\"Instagram\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-instagram w-5 h-5\" aria-hidden=\"true\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\"></line></svg></a><a href=\"https://www.facebook.com/profile.php?id=100069628367326\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors\" aria-label=\"Facebook\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-facebook w-5 h-5\" aria-hidden=\"true\"><path d=\"M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z\"></path></svg></a><a href=\"https://twitter.com/whoknowsmodels\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors\" aria-label=\"Twitter\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-twitter w-5 h-5\" aria-hidden=\"true\"><path d=\"M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z\"></path></svg></a></div></div><div><h3 class=\"font-medium text-sm uppercase tracking-wider mb-4\">Models</h3><ul class=\"space-y-3\"><li><a class=\"text-neutral-400 text-sm hover:text-white transition-colors\" href=\"/women\">Women</a></li><li><a class=\"text-neutral-400 text-sm hover:text-white transition-colors\" href=\"/men\">Men</a></li><li><a class=\"text-neutral-400 text-sm hover:text-white transition-colors\" href=\"/apply\">Apply Now</a></li></ul></div><div><h3 class=\"font-medium text-sm uppercase tracking-wider mb-4\">Company</h3><ul class=\"space-y-3\"><li><a class=\"text-neutral-400 text-sm hover:text-white transition-colors\" href=\"/about\">About Us</a></li><li><a class=\"text-neutral-400 text-sm hover:text-white transition-colors\" href=\"/jobs\">Jobs</a></li><li><a class=\"text-neutral-400 text-sm hover:text-white transition-colors\" href=\"/contact\">Contact</a></li></ul></div></div><div class=\"border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4\"><div class=\"flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6\"><a href=\"tel:+6285721288138\" class=\"flex items-center gap-2 text-neutral-400 text-sm hover:text-white transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone w-4 h-4\" aria-hidden=\"true\"><path d=\"M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384\"></path></svg><span>+62 857-2128-8138</span></a><a href=\"mailto:whoknowsmodels@gmail.com\" class=\"flex items-center gap-2 text-neutral-400 text-sm hover:text-white transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail w-4 h-4\" aria-hidden=\"true\"><path d=\"m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7\"></path><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"></rect></svg><span>whoknowsmodels@gmail.com</span></a></div><p class=\"text-neutral-500 text-xs\">© <!-- -->2026<!-- --> WhoKnows Models. All rights reserved.</p></div></div></footer></div><section aria-label=\"Notifications alt+T\" tabindex=\"-1\" aria-live=\"polite\" aria-relevant=\"additions text\" aria-atomic=\"false\"></section><script>requestAnimationFrame(function(){$RT=performance.now()});</script><script src=\"/_next/static/chunks/250e7d9efb60ea12.js\" id=\"_R_\" async=\"\"></script><div hidden id=\"S:0\"><section class=\"pt-24 lg:pt-32 pb-16 lg:pb-24\"><div class=\"container mx-auto px-4 lg:px-8\"><div class=\"max-w-3xl mx-auto text-center mb-16 lg:mb-24\"><p class=\"text-sm uppercase tracking-wider text-neutral-500 mb-2\">Our Story</p><h1 class=\"font-serif text-4xl lg:text-5xl font-medium tracking-tight mb-6\">About WhoKnows Models</h1><p class=\"text-lg text-neutral-600 leading-relaxed\">Founded with a vision to redefine the modelling industry, WhoKnows Models has grown from a boutique agency to an internationally recognized name in fashion and talent management.</p></div><div class=\"relative aspect-[21/9] mb-16 lg:mb-24 overflow-hidden\"><img alt=\"WhoKnows Models team\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover object-center\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fhero%2Fhero-2.jpg&amp;w=3840&amp;q=75\"/></div><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-16 lg:mb-24\"><div><h2 class=\"font-serif text-3xl font-medium tracking-tight mb-6\">Our Mission</h2><p class=\"text-neutral-600 leading-relaxed mb-4\">At WhoKnows Models, we believe that every individual possesses unique beauty waiting to be discovered. Our mission is to identify, nurture, and promote exceptional talent while maintaining the highest ethical standards in the industry.</p><p class=\"text-neutral-600 leading-relaxed\">We are committed to creating meaningful opportunities for our models, connecting them with leading brands, designers, and publications that share our values of creativity, professionalism, and authenticity.</p></div><div><h2 class=\"font-serif text-3xl font-medium tracking-tight mb-6\">Our Vision</h2><p class=\"text-neutral-600 leading-relaxed mb-4\">We envision a fashion industry that celebrates diversity, embraces innovation, and empowers talent to reach their full potential. WhoKnows Models strives to be at the forefront of this transformation.</p><p class=\"text-neutral-600 leading-relaxed\">By leveraging our global network and industry expertise, we aim to become the bridge between aspiring models and the international fashion stage, one successful career at a time.</p></div></div><div class=\"grid grid-cols-2 lg:grid-cols-4 gap-8 py-12 border-y border-neutral-200 mb-16 lg:mb-24\"><div class=\"text-center\"><div class=\"font-serif text-4xl lg:text-5xl font-medium mb-2\">100+</div><div class=\"text-sm uppercase tracking-wider text-neutral-500\">Models</div></div><div class=\"text-center\"><div class=\"font-serif text-4xl lg:text-5xl font-medium mb-2\">25+</div><div class=\"text-sm uppercase tracking-wider text-neutral-500\">Countries</div></div><div class=\"text-center\"><div class=\"font-serif text-4xl lg:text-5xl font-medium mb-2\">500+</div><div class=\"text-sm uppercase tracking-wider text-neutral-500\">Campaigns</div></div><div class=\"text-center\"><div class=\"font-serif text-4xl lg:text-5xl font-medium mb-2\">10+</div><div class=\"text-sm uppercase tracking-wider text-neutral-500\">Years</div></div></div><div class=\"mb-16 lg:mb-24\"><div class=\"text-center mb-12\"><h2 class=\"font-serif text-3xl lg:text-4xl font-medium tracking-tight mb-4\">Our Values</h2><p class=\"text-lg text-neutral-600 max-w-2xl mx-auto\">The principles that guide everything we do</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\"><div class=\"text-center\"><div class=\"w-16 h-16 rounded-full bg-neutral-100 flex items-center justify-center mx-auto mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-award w-7 h-7\" aria-hidden=\"true\"><path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\"></path><circle cx=\"12\" cy=\"8\" r=\"6\"></circle></svg></div><h3 class=\"font-serif text-xl font-medium mb-2\">Excellence</h3><p class=\"text-neutral-600 text-sm leading-relaxed\">We maintain the highest standards in everything we do, from talent selection to client partnerships.</p></div><div class=\"text-center\"><div class=\"w-16 h-16 rounded-full bg-neutral-100 flex items-center justify-center mx-auto mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users w-7 h-7\" aria-hidden=\"true\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><path d=\"M16 3.128a4 4 0 0 1 0 7.744\"></path><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle></svg></div><h3 class=\"font-serif text-xl font-medium mb-2\">Diversity</h3><p class=\"text-neutral-600 text-sm leading-relaxed\">We celebrate unique beauty in all its forms, representing diverse talent from around the world.</p></div><div class=\"text-center\"><div class=\"w-16 h-16 rounded-full bg-neutral-100 flex items-center justify-center mx-auto mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-globe w-7 h-7\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"></path><path d=\"M2 12h20\"></path></svg></div><h3 class=\"font-serif text-xl font-medium mb-2\">Global Reach</h3><p class=\"text-neutral-600 text-sm leading-relaxed\">With connections across fashion capitals, we open doors to international opportunities.</p></div><div class=\"text-center\"><div class=\"w-16 h-16 rounded-full bg-neutral-100 flex items-center justify-center mx-auto mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-7 h-7\" aria-hidden=\"true\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"></path></svg></div><h3 class=\"font-serif text-xl font-medium mb-2\">Integrity</h3><p class=\"text-neutral-600 text-sm leading-relaxed\">We build lasting relationships based on trust, transparency, and mutual respect.</p></div></div></div><div class=\"bg-neutral-50 p-8 lg:p-12 text-center\"><h2 class=\"font-serif text-2xl lg:text-3xl font-medium tracking-tight mb-4\">Ready to Start Your Journey?</h2><p class=\"text-neutral-600 mb-6 max-w-xl mx-auto\">Whether you&#x27;re an aspiring model or a brand seeking exceptional talent, we&#x27;re here to help you achieve your goals.</p><div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\"><a href=\"/apply\" class=\"px-8 py-3 bg-black text-white font-medium text-sm uppercase tracking-wider hover:bg-neutral-800 transition-colors\">Apply Now</a><a href=\"/contact\" class=\"px-8 py-3 border border-black text-black font-medium text-sm uppercase tracking-wider hover:bg-black hover:text-white transition-colors\">Contact Us</a></div></div></div></section><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://whoknowsmodels.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"About\",\"item\":\"https://whoknowsmodels.com/about\"}]}</script><!--$--><!--/$--></div><script>$RB=[];$RV=function(a){$RT=performance.now();for(var b=0;b<a.length;b+=2){var c=a[b],e=a[b+1];null!==e.parentNode&&e.parentNode.removeChild(e);var f=c.parentNode;if(f){var g=c.previousSibling,h=0;do{if(c&&8===c.nodeType){var d=c.data;if(\"/$\"===d||\"/&\"===d)if(0===h)break;else h--;else\"$\"!==d&&\"$?\"!==d&&\"$~\"!==d&&\"$!\"!==d&&\"&\"!==d||h++}d=c.nextSibling;f.removeChild(c);c=d}while(c);for(;e.f